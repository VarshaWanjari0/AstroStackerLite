<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000"
    android:keepScreenOn="true">

    <!-- Camera Preview -->
    <TextureView
        android:id="@+id/textureView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Main UI Overlay -->
    <FrameLayout
        android:id="@+id/mainUiLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageButton
            android:id="@+id/btnDevOptions"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="top|end"
            android:layout_margin="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_settings"
            app:tint="#FFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCapture"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="32dp"
            android:backgroundTint="#FF4444"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="40dp"
            app:icon="@drawable/ic_shutter"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="48dp" />

        <!-- Anti-shake Timer -->
        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="5"
            android:textColor="#FF4444"
            android:textSize="144sp"
            android:textStyle="bold"
            android:typeface="monospace"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Unobtrusive Capture Indicator (Replaces the dark fullscreen overlay) -->
    <LinearLayout
        android:id="@+id/processingOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_pill"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:visibility="gone"
        android:elevation="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        
        <ProgressBar 
            android:layout_width="24dp" 
            android:layout_height="24dp" 
            android:indeterminateTint="#FF4444" 
            android:layout_marginEnd="12dp"/>
            
        <TextView 
            android:id="@+id/tvProgress" 
            android:layout_width="wrap_content" 
            android:layout_height="wrap_content" 
            android:text="Capturing: 0/25" 
            android:textColor="#FFF" 
            android:textSize="16sp" 
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Developer Options Panel -->
    <ScrollView
        android:id="@+id/devOptionsPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:visibility="gone"
        android:elevation="20dp"
        android:fillViewport="true">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DEVELOPER OPTIONS" android:textColor="#FF4444" android:textSize="18sp" android:textStyle="bold" android:layout_centerVertical="true"/>
                <ImageButton android:id="@+id/btnCloseDev" android:layout_width="48dp" android:layout_height="48dp" android:layout_alignParentEnd="true" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_close_clear_cancel" app:tint="#FFF" />
            </RelativeLayout>

            <!-- Lag Free Preview Toggle -->
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swAutoPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Auto-Exposure Preview (Fix Lag)"
                android:textColor="#FFF"
                android:checked="true"
                android:layout_marginBottom="16dp"/>

            <!-- Hot Pixel Toggle -->
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swHotPixel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hot Pixel Remover"
                android:textColor="#FFF"
                android:checked="true"
                android:layout_marginBottom="16dp"/>

            <!-- Brightness Multiplier -->
            <TextView android:id="@+id/tvDevBrightness" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Brightness Boost: 1.0x" android:textColor="#FFF" android:textStyle="bold"/>
            <SeekBar android:id="@+id/sbDevBrightness" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:layout_marginBottom="16dp" android:max="100" android:progress="0" />

            <!-- Zoom -->
            <TextView android:id="@+id/tvDevZoom" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Digital Zoom: 1.0x" android:textColor="#FFF" android:textStyle="bold"/>
            <SeekBar android:id="@+id/sbDevZoom" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:layout_marginBottom="16dp" android:max="100" android:progress="0" />

            <!-- ISO -->
            <TextView android:id="@+id/tvDevIso" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ISO: 800" android:textColor="#FFF" android:textStyle="bold"/>
            <SeekBar android:id="@+id/sbDevIso" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:layout_marginBottom="16dp" android:max="100" android:progress="25" />

            <!-- Exposure -->
            <TextView android:id="@+id/tvDevExposure" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Exposure: 100ms" android:textColor="#FFF" android:textStyle="bold"/>
            <SeekBar android:id="@+id/sbDevExposure" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:layout_marginBottom="16dp" android:max="100" android:progress="50" />

            <!-- Stack Count -->
            <TextView android:id="@+id/tvDevStack" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Stack Target: 25 frames" android:textColor="#FFF" android:textStyle="bold"/>
            <SeekBar android:id="@+id/sbDevStack" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:layout_marginBottom="16dp" android:max="100" android:progress="24" />

            <!-- Focus Distance -->
            <TextView android:id="@+id/tvDevFocus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Focus: Infinity" android:textColor="#FFF" android:textStyle="bold"/>
            <SeekBar android:id="@+id/sbDevFocus" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:layout_marginBottom="24dp" android:max="100" android:progress="0" />

            <!-- Toggles -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="32dp">
                <Button android:id="@+id/btnDevFormat" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Format: DNG" android:backgroundTint="#333" android:textColor="#FFF" android:layout_marginEnd="8dp"/>
                <Button android:id="@+id/btnDevTorch" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Torch: OFF" android:backgroundTint="#333" android:textColor="#FFF" android:layout_marginStart="8dp"/>
            </LinearLayout>
            
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>